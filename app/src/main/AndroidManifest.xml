<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.android.car.aasdk">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- For the wireless-projection TCP listener in AaSdkUsbService. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- listenUsingRfcommWithServiceRecord registers an SDP record, which
         needs BLUETOOTH_ADVERTISE on top of BLUETOOTH_CONNECT. -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <!-- registerSoftApCallback (AaSdkSoftApHotspot) requires NETWORK_SETTINGS. -->
    <uses-permission android:name="android.permission.NETWORK_SETTINGS" />
    <!-- TetheringManager.startTethering/stopTethering (AaSdkSoftApHotspot):
         this is what actually provisions the AP interface's IP/DHCP, which
         WifiManager.startTetheredHotspot() alone does not do. See
         com.android.car.aasdk.xml for why this needs a privapp allowlist
         entry (signature|privileged) on top of this manifest declaration. -->
    <uses-permission android:name="android.permission.TETHER_PRIVILEGED" />
    <!-- Lets CarUsbHandler recognize this app as an AOAP handler and auto-select
         it (skipping its multi-app disambiguation dialog) instead of just a
         generic usb-device handler. See AaSdkAoapService/device_filter.xml. -->
    <uses-permission android:name="android.car.permission.CAR_HANDLE_USB_AOAP_DEVICE" />
    <!-- Lets AaSdkUsbService.requestWirelessStartConfirmation() call
         startActivity(AaSdkWirelessConfirmActivity) directly from the
         background service. Without this, Android's background-activity-
         launch policy silently blocks that call whenever nothing from this
         app is currently visible (confirmed live 2026-07-09: "Background
         activity launch blocked!...result code=102"). A prior fix routed
         around this via a full-screen-intent notification instead, but that
         depends on POST_NOTIFICATIONS (a runtime permission whose
         default-permissions pre-grant only applies at initial user
         creation, not on every incremental flash) AND on the app's overall
         notification importance not being blocked at the NotificationManager
         level (confirmed live 2026-07-09: every post was silently dropped,
         numBlocked=20/numPosted=0, even after POST_NOTIFICATIONS was
         granted), two failure points outside this app's own control, for
         UI that AAOS doesn't reliably surface as full-screen anyway. This
         signature|privileged permission is the direct, Android-blessed way
         for a privileged app to start activities from the background with
         no such dependencies; see com.android.car.aasdk.xml for the
         matching privapp-permissions allowlist entry it requires on top of
         this declaration. -->
    <uses-permission android:name="android.permission.START_ACTIVITIES_FROM_BACKGROUND" />
    <!-- Lets AaSdkBootReceiver start AaSdkUsbService right at boot, so a
         BT-only connect shows the wireless confirm dialog even if nothing
         has opened this app yet this boot (see that receiver's comment). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:label="Android Auto HU"
        android:icon="@mipmap/ic_launcher">

        <!-- Receives USB_DEVICE_ATTACHED, handles AOAP mode switch -->
        <activity
            android:name=".UsbAttachActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>

        <!-- Full-screen AA display -->
        <activity
            android:name=".AaSdkScreenActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- "Start Android Auto (Wireless)?" prompt, shown by AaSdkUsbService
             when a phone connects over BT with no USB device attached. -->
        <activity
            android:name=".AaSdkWirelessConfirmActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />

        <!-- Background service that holds the C++ session -->
        <service
            android:name=".AaSdkUsbService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- Bound by android.car.usb.handler (CarUsbHandler) only, to ask whether
             this app supports/wants a just-attached device before switching it to
             AOAP mode. Must require MANAGE_USB per android.car.AoapService's
             contract, so no other app can bind to it. -->
        <service
            android:name=".AaSdkAoapService"
            android:exported="true"
            android:permission="android.permission.MANAGE_USB" />

        <!-- Starts AaSdkUsbService at boot so its RFCOMM listener exists
             before the user does anything, see AaSdkBootReceiver's own
             comment. -->
        <receiver
            android:name=".AaSdkBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
